# TikTok/Reels MVP — Environment Variables
# Copy to .env and override as needed:
#   cp .env.example .env
#
# DATABASE_URL and REDIS_URL are set in docker-compose.yml's environment block for
# the compose network. Override here only if running outside compose.

# PostgreSQL connection string (async driver)
# DATABASE_URL=postgresql+asyncpg://tiktok:tiktok@db:5432/tiktok_reels

# Redis connection string (feed cache + counters)
# REDIS_URL=redis://redis:6379/0

# Host port for the app container (used by docker-compose.yml)
# APP_PORT=8010
